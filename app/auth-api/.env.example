# Auth-api: copy to .env and fill in values.
# Used when running from app/auth-api (make server, make test).

AUTH_DB_URL=postgresql+psycopg2://auth_user:auth_pass@auth-db:5432/auth_db
JWT_ALGORITHM=RS256
# RS256: private key for signing tokens (file path or PEM string; use \\n for newlines in env)
JWT_PRIVATE_KEY_PATH=
JWT_PRIVATE_KEY=
# RS256: public key for verifying tokens (e.g. /me)
JWT_PUBLIC_KEY_PATH=
JWT_PUBLIC_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Google OIDC (optional)
CLIENT_ID=
CLIENT_SECRET=
SESSION_SECRET_KEY=change-me-session-secret
FRONTEND_URL=http://localhost:3000

# Kafka (optional; if unset, UserCreated uses in-memory publisher)
# For docker-compose, this will point at the `kafka` service defined there.
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_USER_CREATED_TOPIC=user.created
