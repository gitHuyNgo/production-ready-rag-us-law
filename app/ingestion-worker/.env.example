# Ingestion-worker: copy to .env and fill in values.
# Used when running from app/ingestion-worker (make ingest, make test).

OPENAI_API_KEY=your_openai_api_key
# Optional for rerank; leave empty if not using Cohere
COHERE_API_KEY=

WEAVIATE_URL=http://weaviate:8080
REDIS_URL=redis://redis:6379

# Optional
# ENVIRONMENT=development
# LOG_LEVEL=INFO
