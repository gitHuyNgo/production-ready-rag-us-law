# API Gateway: copy to .env and fill in values.
# Run from app/api-gateway (make server, make test).

# Upstreams (use service names in Docker; localhost when running gateway alone)
AUTH_API_URL=http://auth-api:8001
USER_API_URL=http://user-api:8002
CHAT_API_URL=http://chat-api:8000

# JWT verification (RS256: public key must match auth-api key pair)
JWT_ALGORITHM=RS256
JWT_PUBLIC_KEY_PATH=public.pem

# CORS (comma-separated or JSON array)
# CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Rate limits
# RATE_LIMIT_DEFAULT=100/minute
# RATE_LIMIT_STRICT=20/minute
