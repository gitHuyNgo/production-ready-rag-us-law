# Single env file for all app services (chat-api, ingestion-worker).
# Copy to app/.env and fill in values. For local dev from a service dir (e.g. app/chat-api),
# set APP_ENV_FILE=../.env so the shared lib loads this file.

OPENAI_API_KEY=your_openai_api_key
COHERE_API_KEY=your_cohere_api_key

# Core vector DB / cache configuration
WEAVIATE_URL=http://weaviate:8080
REDIS_URL=redis://redis:6379

# Optional semantic cache tuning (commented out defaults)
# CACHE_TTL_SECONDS=86400
# CACHE_SIMILARITY_THRESHOLD=0.95
# CACHE_EMBED_DIM=3072

# Environment and logging
ENVIRONMENT=development
LOG_LEVEL=INFO

